---
layout: layouts/base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: "/tags/{{ tag | urlencode }}/"
eleventyComputed:
  pageTitle: "Clash Verge {{ tag }} 内容集合"
  description: "Clash Verge {{ tag }} 相关内容集合。"
---
<main class="light-section">
  <div class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow" style="color:#0f5db8;">Tags</p>
        <h1>Clash Verge {{ tag }} 内容集合</h1>
        <p>当前主题下的文章入口。</p>
      </div>
      <a class="soft-button" style="color:#152033;" href="/tags/">返回 Tags</a>
    </div>
    <div class="post-list">
      {% for post in collections.posts %}
        {% if post.data.tags and tag in post.data.tags %}
        <article class="post-card">
          <img src="https://tse-mm.bing.com/th?q={{ post.data.imageKeyword or post.data.title | urlencode }}" alt="{{ post.data.title }} 配图" loading="lazy">
          <time datetime="{{ post.date | htmlDateString }}">{{ post.date | dateText }}</time>
          <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
          <p>{{ post.data.description }}</p>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</main>
