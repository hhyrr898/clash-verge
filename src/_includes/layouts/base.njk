<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% set docTitle = pageTitle or title or site.name %}
    {% set metaDescription = description or site.description %}
    {% set canonical = site.url + (canonicalUrl or page.url or "/") %}
    <title>{{ docTitle }} | {{ site.brand }}</title>
    <meta name="description" content="{{ metaDescription }}">
    {% if noindex %}
    <meta name="robots" content="noindex,follow">
    {% else %}
    <meta name="robots" content="index,follow,max-image-preview:large">
    {% endif %}
    <link rel="canonical" href="{{ canonical }}">
    <meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}">
    <meta property="og:title" content="{{ docTitle }}">
    <meta property="og:description" content="{{ metaDescription }}">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:site_name" content="{{ site.brand }}">
    <meta property="og:locale" content="zh_CN">
    <meta property="og:image" content="{{ site.url }}{{ site.logo }}">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" href="/favicon.ico">
    <link rel="alternate icon" href="/assets/logo.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/assets/styles.css">
    <script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.brand,
  "url": site.url,
  "description": site.description
} | dump | safe }}
    </script>
    {% if video %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "VideoObject",
        "name": {{ title | dump | safe }},
        "description": {{ videoDescription or description | dump | safe }},
        "thumbnailUrl": ["https://tse-mm.bing.com/th?q={{ imageKeyword or title | urlencode }}"],
        "uploadDate": "{{ page.date | htmlDateString }}",
        "contentUrl": "{{ site.url }}{{ video }}"
      }
    </script>
    {% endif %}
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="{{ site.name }}">
          <img src="{{ site.logo }}" alt="{{ site.brand }} 标识" width="42" height="42">
          <span>{{ site.brand }} Hub</span>
        </a>
        <nav class="main-nav" aria-label="主导航">
          <a href="/">首页</a>
          <a href="/blog/">博客</a>
          <a href="/dows.html">下载中心</a>
          <a href="/tags/">Tags</a>
        </nav>
      </div>
    </header>
    {{ content | safe }}
    <footer class="site-footer">
      <div class="container footer-grid">
        <section>
          <h2>{{ site.brand }} Hub</h2>
          <p>围绕跨平台客户端、桌面体验、移动端设置与日常使用场景整理内容。</p>
        </section>
        <nav aria-label="底部导航">
          <a href="/">首页</a>
          <a href="/blog/">博客</a>
          <a href="/download.html">下载中心</a>
          <a href="/sitemap.xml">站点地图</a>
        </nav>
      </div>
    </footer>
    <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js" defer></script>
    <script>window.addEventListener("load",function(){if(window.LA){LA.init({id:"3J1iExMgyFcatcVQ",ck:"3J1iExMgyFcatcVQ"})}})</script>
  </body>
</html>
